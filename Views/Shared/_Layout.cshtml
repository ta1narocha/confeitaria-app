<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestão da Confeitaria</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ConfeitariaApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
            <style>
                .nav-confeitaria { background-color: #ff85a1; } 
                .nav-link:hover { color: #5d4037 !important; background: #fff; border-radius: 20px; }
                .btn-confeitaria { background-color: #5d4037; color: white; border-radius: 25px; padding: 8px 25px; border: none; }
                .btn-confeitaria:hover { background-color: #3e2723; color: white; }
            </style>

            <nav class="navbar navbar-expand-lg navbar-dark nav-confeitaria shadow-sm">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">🧁 Gestão da Confeitaria</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Ingrediente" asp-action="Index"> Ingredientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Receita" asp-action="Index"> Receitas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Bolo" asp-action="Index"> Bolos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Pedido" asp-action="Index"> Pedidos</a>
                        </li>
                        </ul>
                        <div class="d-flex">
                            <a class="btn btn-confeitaria" asp-controller="Pedido" asp-action="Index"> Meus Pedidos</a>
                        </div>
                    </div>
                </div>
            </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        
        <style>
            
            body {
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            main {
                flex: 1;
                padding-bottom: 50px; 
            }

            footer {
                background-color: #fff;
                z-index: 10; 
            }
        </style>

        <div class="container">
            &copy; 2026 - Gestão da Confeitaria - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
