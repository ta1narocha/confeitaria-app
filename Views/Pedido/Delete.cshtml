@model ConfeitariaApp.Models.Pedido

@{
    ViewData["Title"] = "Excluir Pedido";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h3>🗑️ Excluir Pedido</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>⚠️ Atenção!</strong> Tem certeza que deseja excluir este pedido?
                        <br />
                        <small>Esta ação não pode ser desfeita.</small>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4">Cliente</dt>
                        <dd class="col-sm-8">@Model.Cliente</dd>

                        <dt class="col-sm-4">Bolo</dt>
                        <dd class="col-sm-8">@(Model.Bolo?.Nome ?? "N/A")</dd>

                        <dt class="col-sm-4">Valor</dt>
                        <dd class="col-sm-8">R$ @Model.Valor.ToString("F2")</dd>

                        <dt class="col-sm-4">Data Pedido</dt>
                        <dd class="col-sm-8">@Model.DataPedido.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Data Entrega</dt>
                        <dd class="col-sm-8">@Model.DataEntrega.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">@Model.Status</dd>

                        <dt class="col-sm-4">Pagamento</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.FormaPagamento) ? "-" : Model.FormaPagamento)</dd>

                        <dt class="col-sm-4">Observações</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Observacoes) ? "-" : Model.Observacoes)</dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger">✅ Confirmar Exclusão</button>
                            <a asp-action="Index" class="btn btn-secondary">↩️ Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>