@model ConfeitariaApp.Models.Pedido

@{
    ViewData["Title"] = "Detalhes do Pedido";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-info text-white">
            <h3>📋 Detalhes do Pedido #@Model.Id</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5>Informações do Cliente</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Cliente</dt>
                        <dd class="col-sm-8">@Model.Cliente</dd>

                        <dt class="col-sm-4">Data Pedido</dt>
                        <dd class="col-sm-8">@Model.DataPedido.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-4">Data Entrega</dt>
                        <dd class="col-sm-8">@Model.DataEntrega.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">@Model.Status</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <h5>Informações do Produto</h5>
                    <dl class="row">
                       
                        <dt class="col-sm-4">Bolo</dt>
                        <dd class="col-sm-8">@(Model.Bolo?.Nome ?? "Não informado")</dd>

                        <dt class="col-sm-4">Valor</dt>
                        <dd class="col-sm-8">R$ @Model.Valor.ToString("F2")</dd>

                        <dt class="col-sm-4">Pagamento</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.FormaPagamento) ? "-" : Model.FormaPagamento)</dd>

                        <dt class="col-sm-4">Observações</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Observacoes) ? "-" : Model.Observacoes)</dd>
                    </dl>
                </div>
            </div>

            @if (Model.Bolo?.Receita != null)
            {
                <hr />
                <h5>Detalhamento da Receita</h5>
                <dl class="row">
                    <dt class="col-sm-3">Receita Base</dt>
                    <dd class="col-sm-9">@Model.Bolo.Receita.Nome</dd>

                    <dt class="col-sm-3">Custo Ingredientes</dt>
                    <dd class="col-sm-9">R$ @Model.Bolo.CustoIngredientes.ToString("F2")</dd>

                    <dt class="col-sm-3">Lucro</dt>
                    <dd class="col-sm-9">R$ @(Model.Bolo.PrecoFinal - Model.Bolo.CustoIngredientes).ToString("F2")</dd>
                </dl>
            }

            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">✏️ Editar</a>
                <a asp-action="Index" class="btn btn-secondary">↩️ Voltar</a>
            </div>
        </div>
    </div>
</div>