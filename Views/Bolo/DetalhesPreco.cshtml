@model ConfeitariaApp.Models.Bolo
@{
    ViewData["Title"] = "Detalhes do Preço";
    var custoOperacional = Model.CustoIngredientes * 0.15m;
    var subtotal = Model.CustoIngredientes * 1.15m;
    var margemLucro = subtotal * 0.5m;
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold" style="color: #ff85a1;">📊 Ficha Técnica de Custos</h2>
        <h4 class="text-muted">Bolo: @Model.Nome</h4>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header border-0 py-3" style="background-color: #5d4037;">
            <h5 class="card-title text-white mb-0 text-center"><i class="bi bi-calculator"></i> Detalhamento do Cálculo</h5>
        </div>

        <div class="card-body p-4">
          
            <div class="mb-4">
                <h5 class="fw-bold border-bottom pb-2" style="color: #5d4037;">1. Custo dos Ingredientes</h5>
                <div class="alert alert-info">
                    <strong>Custo Total dos Ingredientes:</strong> R$ @Model.CustoIngredientes.ToString("N2")
                    <br />
                    <small>* O cálculo considera todos os ingredientes da receita base multiplicado pelo fator @Model.FatorMultiplicador</small>
                </div>
            </div>

            
            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <div class="p-3 rounded-4 bg-light text-center shadow-sm h-100">
                        <h6 class="text-muted text-uppercase small fw-bold">Custos Operacionais (15%)</h6>
                        <p class="h5 mb-0">R$ @custoOperacional.ToString("N2")</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-4 bg-light text-center shadow-sm h-100 border-start border-4 border-info">
                        <h6 class="text-muted text-uppercase small fw-bold">Subtotal (Custo Real)</h6>
                        <p class="h5 mb-0">R$ @subtotal.ToString("N2")</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-4 bg-light text-center shadow-sm h-100 border-start border-4 border-warning">
                        <h6 class="text-muted text-uppercase small fw-bold">Margem de Lucro (50%)</h6>
                        <p class="h5 mb-0">R$ @margemLucro.ToString("N2")</p>
                    </div>
                </div>
            </div>

            
            <div class="alert alert-success border-0 rounded-4 p-4 text-center shadow">
                <h6 class="text-uppercase fw-bold">Preço Final Sugerido para Venda</h6>
                <h1 class="display-4 fw-bold mb-0">R$ @Model.PrecoFinal.ToString("N2")</h1>
            </div>

            
            <div class="d-flex gap-2 mt-4">
                <button onclick="window.print()" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-printer"></i> Imprimir Ficha
                </button>
                <a asp-action="Index" class="btn btn-confeitaria flex-grow-1 shadow-sm">
                    Voltar para Lista de Bolos
                </a>
            </div>
        </div>
    </div>
</div>