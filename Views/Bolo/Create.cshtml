@model ConfeitariaApp.Models.Bolo
@{
    ViewData["Title"] = "Novo Bolo";
    var receitas = ViewBag.Receitas as List<ConfeitariaApp.Models.Receita>;
}

<style>
    .btn-confeitaria {
        background-color: #ff85a1;
        color: white;
        border: none;
        border-radius: 50px;
    }

        .btn-confeitaria:hover {
            background-color: #e06b86;
            color: white;
        }

    .card-confeitaria {
        border: none;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .header-confeitaria {
        background-color: #ff85a1;
        color: white;
        border-radius: 20px 20px 0 0 !important;
    }

    .form-label {
        color: #5d4037;
        font-weight: bold;
    }

    .alert-custo {
        background-color: #fff5f5;
        border: 1px solid #ff85a1;
        color: #5d4037;
        border-radius: 15px;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-confeitaria">
                <div class="card-header header-confeitaria text-center py-3">
                    <h3 class="mb-0">🧁 Cadastrar Novo Bolo</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                       
                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label">Nome do Bolo</label>
                            <input asp-for="Nome" class="form-control rounded-pill" placeholder="Ex: Morango com Chantilly" />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>

                        
                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label">Descrição / Detalhes</label>
                            <textarea asp-for="Descricao" class="form-control" rows="3" style="border-radius: 15px;"></textarea>
                            <span asp-validation-for="Descricao" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            
                            <div class="col-md-7 mb-3">
                                <label asp-for="ReceitaId" class="form-label">Receita Base</label>
                                <select asp-for="ReceitaId" class="form-select rounded-pill" required>
                                    <option value="">Selecione a receita...</option>
                                    @if (receitas != null)
                                    {
                                        foreach (var receita in receitas)
                                        {
                                            <option value="@receita.Id">@receita.Nome</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="ReceitaId" class="text-danger small"></span>
                            </div>


                            <div class="col-md-5 mb-3">
                                <label asp-for="FatorMultiplicador" class="form-label">Tamanho (Fator)</label>
                                <input asp-for="FatorMultiplicador" class="form-control rounded-pill" type="number" step="0.1" value="1" />
                                <span asp-validation-for="FatorMultiplicador" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="alert alert-custo mt-2">
                            <div class="d-flex">
                                <div class="me-3">📊</div>
                                <div>
                                    <small><strong>Cálculo Automático:</strong> Custo da Receita × Fator. <br> Inclui 15% operacional + 50% margem de lucro.</small>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-confeitaria btn-lg py-2">💾 Salvar Bolo</button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

