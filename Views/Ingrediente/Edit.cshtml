@model ConfeitariaApp.Models.Ingrediente

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 text-center">
                    <h2 class="fw-bold" style="color: #ff85a1;">✏️ Editar Ingrediente</h2>
                    <p class="text-muted">Atualize as informações para o cálculo de custos</p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-3">
                           
                            <div class="col-12">
                                <label asp-for="Nome" class="form-label fw-bold">Nome do Ingrediente</label>
                                <input asp-for="Nome" class="form-control rounded-pill shadow-sm" />
                                <span asp-validation-for="Nome" class="text-danger small"></span>
                            </div>

                            
                            <div class="col-md-4">
                                <label asp-for="UnidadeBase" class="form-label fw-bold">Unidade Base</label>
                                <select asp-for="UnidadeBase" class="form-select rounded-pill shadow-sm">
                                    <option value="g">grama (g)</option>
                                    <option value="ml">mililitro (ml)</option>
                                    <option value="un">unidade (un)</option>
                                </select>
                                <span asp-validation-for="UnidadeBase" class="text-danger small"></span>
                            </div>

                           
                            <div class="col-md-4">
                                <label asp-for="QuantidadeEmbalagem" class="form-label fw-bold">Qtd. Embalagem</label>
                                <input asp-for="QuantidadeEmbalagem" class="form-control rounded-pill shadow-sm" type="number" step="0.001" />
                                <span asp-validation-for="QuantidadeEmbalagem" class="text-danger small"></span>
                                <div class="form-text">Total da embalagem comprada.</div>
                            </div>

                            
                            <div class="col-md-4">
                                <label asp-for="PrecoEmbalagem" class="form-label fw-bold">Preço Pago (R$)</label>
                                <input asp-for="PrecoEmbalagem" class="form-control rounded-pill shadow-sm" type="number" step="0.01" />
                                <span asp-validation-for="PrecoEmbalagem" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3">
                            <strong>Preço Unitário:</strong> R$ @Model.PrecoUnitario.ToString("F4") por @Model.UnidadeBase
                        </div>

                        
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-confeitaria flex-grow-1 shadow-sm">
                                <i class="bi bi-check-circle"></i> Salvar Alterações
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}