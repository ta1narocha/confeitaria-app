@model ConfeitariaApp.Models.ItemReceita

@{
    ViewData["Title"] = "Adicionar Ingrediente";
}

<style>
    .btn-confeitaria {
        background-color: #ff85a1;
        color: white;
        border: none;
    }

    .btn-confeitaria:hover {
        background-color: #e06b86;
        color: white;
    }
</style>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header" style="background-color: #ff85a1; color: white;">
                    <h3 class="mb-0">➕ Adicionar Ingrediente</h3>
                    <h5 class="mt-2 mb-0">🍰 @ViewBag.ReceitaNome</h5>
                </div>
                <div class="card-body">
                    <form asp-action="AdicionarIngrediente" method="post">
                        <input type="hidden" asp-for="ReceitaId" value="@ViewBag.ReceitaId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="IngredienteId" class="form-label fw-bold" style="color: #5d4037;">Ingrediente</label>
                            <select asp-for="IngredienteId" class="form-control" asp-items="@(new SelectList(ViewBag.Ingredientes, "Id", "Nome"))">
                                <option value="">Selecione um ingrediente</option>
                            </select>
                            <span asp-validation-for="IngredienteId" class="text-danger"></span>
                            <small class="form-text text-muted">Selecione o ingrediente que será usado na receita</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Quantidade" class="form-label fw-bold" style="color: #5d4037;">Quantidade (g/ml)</label>
                            <input asp-for="Quantidade" class="form-control" type="number" step="0.01" placeholder="Ex: 500" />
                            <span asp-validation-for="Quantidade" class="text-danger"></span>
                            <small class="form-text text-muted">Digite a quantidade em gramas (g) ou mililitros (ml)</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Observacao" class="form-label fw-bold" style="color: #5d4037;">Observação (opcional)</label>
                            <input asp-for="Observacao" class="form-control" placeholder="Ex: Peneirado, em temperatura ambiente" />
                        </div>

                        <div class="alert" style="background-color: #ffe0e0; color: #5d4037; border: 1px solid #ff85a1;">
                            <strong>ℹ️ Dica:</strong> O custo será calculado automaticamente baseado no preço por grama/ml do ingrediente.
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-confeitaria">💾 Adicionar Ingrediente</button>
                            <a asp-action="Edit" asp-route-id="@ViewBag.ReceitaId" class="btn btn-secondary">↩️ Voltar para Receita</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}