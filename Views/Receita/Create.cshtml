@model ConfeitariaApp.Models.Receita
@{
    ViewData["Title"] = "Nova Receita";
}

<style>
    .btn-confeitaria {
        background-color: #ff85a1;
        color: white;
        border: none;
        border-radius: 50px;
    }

        .btn-confeitaria:hover {
            background-color: #e06b86;
            color: white;
        }

    .card-confeitaria {
        border: none;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .header-chocolate {
        background-color: #5d4037;
        color: white;
        border-radius: 20px 20px 0 0 !important;
    }

    .ingrediente-row:hover {
        background-color: #fff5f5;
    }
</style>

<div class="container mt-5">
    <form asp-action="Create" method="post" id="receitaForm">
        <div class="row">
            <div class="col-md-8">
                <div class="card card-confeitaria shadow-sm">
                    <div class="card-header header-chocolate py-3">
                        <h3 class="mb-0">🍰 Criar Nova Receita</h3>
                    </div>
                    <div class="card-body p-4">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label fw-bold">Nome da Receita</label>
                            <input asp-for="Nome" class="form-control rounded-pill" placeholder="Ex: Bolo de Uva Verde" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label fw-bold">Descrição</label>
                            <textarea asp-for="Descricao" class="form-control" rows="2" style="border-radius:15px;"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Rendimento" class="form-label fw-bold">Rendimento</label>
                            <input asp-for="Rendimento" class="form-control rounded-pill" placeholder="Ex: 10 fatias" />
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">🥄 Ingredientes</h5>
                            <button type="button" class="btn btn-confeitaria btn-sm" onclick="adicionarLinha()">➕ Adicionar</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Ingrediente</th>
                                        <th width="150">Qtd</th>
                                        <th width="150">Custo</th>
                                        <th width="50"></th>
                                    </tr>
                                </thead>
                                <tbody id="ingredientesBody"></tbody>
                                <tfoot>
                                    <tr class="fw-bold fs-5">
                                        <td colspan="2" class="text-end">Total:</td>
                                        <td id="custoTotal">R$ 0,00</td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-confeitaria btn-lg">💾 Salvar Receita</button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Voltar</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card card-confeitaria p-3" style="background-color: #fdf2f4; border: 1px solid #ff85a1;">
                    <h5 class="fw-bold">📊 Resumo</h5>
                    <div id="resumoIngredientes" class="small text-muted mb-3">Nenhum ingrediente adicionado.</div>
                    <hr />
                    <h4 class="text-center fw-bold" style="color: #5d4037;" id="resumoTotal">R$ 0,00</h4>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let ingredientesList = [];
        let contador = 0;

        async function carregarIngredientes() {
            const resp = await fetch('/Receita/GetIngredientesJson');
            ingredientesList = await resp.json();
            adicionarLinha();
        }

        function adicionarLinha() {
            const id = `linha_${contador++}`;
            let options = ingredientesList.map(i => `<option value="${i.id}" data-preco="${i.precoUnitario}" data-unidade="${i.unidadeBase}">${i.nome}</option>`).join('');

            const html = `
                <tr id="${id}" class="ingrediente-row">
                    <td><select name="IngredienteIds" class="form-select select-ing" onchange="calcular('${id}')" required><option value="">Selecione...</option>${options}</select></td>
                    <td><div class="input-group"><input name="Quantidades" type="number" step="0.01" class="form-control input-qtd" oninput="calcular('${id}')" required><span class="input-group-text label-un">g</span></div></td>
                    <td class="col-custo fw-bold">R$ 0,00</td>
                    <td><button type="button" class="btn btn-link text-danger" onclick="remover('${id}')">🗑️</button></td>
                </tr>`;
            document.getElementById('ingredientesBody').insertAdjacentHTML('beforeend', html);
        }

        function calcular(id) {
            const linha = document.getElementById(id);
            const opt = linha.querySelector('.select-ing option:checked');
            const preco = parseFloat(opt.dataset.preco) || 0;
            const qtd = parseFloat(linha.querySelector('.input-qtd').value) || 0;

            linha.querySelector('.label-un').innerText = opt.dataset.unidade || 'g';
            linha.querySelector('.col-custo').innerText = `R$ ${(preco * qtd).toFixed(2)}`;
            atualizarTotal();
        }

        function atualizarTotal() {
            let total = 0;
            document.querySelectorAll('.col-custo').forEach(el => total += parseFloat(el.innerText.replace('R$ ', '')) || 0);
            document.getElementById('custoTotal').innerText = `R$ ${total.toFixed(2)}`;
            document.getElementById('resumoTotal').innerText = `R$ ${total.toFixed(2)}`;
        }

        function remover(id) { document.getElementById(id).remove(); atualizarTotal(); }
        carregarIngredientes();
    </script>
}
